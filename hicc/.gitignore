# Generated by Cargo
# will have compiled files and executables
**/target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# General build artifacts
a.out
*.so
*.gch
CMakeFiles
CMakeCache.txt
cmake_install.cmake
main
build

# IDE / editor files
c_cpp_properties.json
settings.json
*.swp
*.bak

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/

# ─── hicc-cbindgen auto-generated files ──────────────────────────────
# These are regenerated by `make run` and should not be tracked.
# Pattern: hicc_<name>.h / hicc_<name>.py / hicc_<name>.pxd (cbindgen output)
# Pattern: <crate_name>.h / <crate_name>.py (cbindgen output for non-hicc names)
hicc-rs-examples/**/hicc_*.h
hicc-rs-examples/**/hicc_*.py
hicc-rs-examples/**/hicc_*.pxd
hicc-rs-examples/**/foo_bar_baz.h
hicc-rs-examples/**/foo_bar_baz.py
hicc-rs-examples/**/foreign_type.py

# ─── BUT keep hand-written no_std files ───────────────────────────────
!hicc-rs-examples/no-std/c/hicc_no_std_demo.h
!hicc-rs-examples/no-std/python/hicc_no_std_demo.py

# ─── Stray generated files at root ────────────────────────────────────
/*.h
/*.py

# ─── Cython generated files ────────────────────────────────────────────
# .c and .so from Cython compilation, .h and .pxd from hicc-cbindgen
**/cython/*.c
**/cython/*.so
**/cython/*.h
**/cython/*.pxd
**/cython/build/

# ─── Stray generated/test files ──────────────────────────────────────
hicc-rs/foreign_type_test.h
hicc-rs/src/1
hicc-rs/src/core/1