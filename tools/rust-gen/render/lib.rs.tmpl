//! 自动生成：hicc_usage_{{ name }}
//!
//! 由 tools/rust-gen/rust_gen.py 从 ../ast/symbols.json 生成。
//! 请勿手动编辑；如需调整请修改 tools/rust-gen/special.yaml 后重新生成。

hicc::cpp! {
    #include "hicc_usages/{{ name }}.h"
{% if active_cpp_extras %}

    // ============================================================
    // 自动生成的活跃 C++ 包装（untouched C++ 模式）
    // 这些代码是 Rust crate 正常工作所必需的（类模板 typedef + factory 等）
    // ============================================================
{% for code in active_cpp_extras %}{% for line in code.split("\n") %}
    {{ line }}
{% endfor %}{% endfor %}{% endif %}
{% if suggested_wrappers %}

    // ============================================================
    // 自动生成的建议包装（untouched C++ 模式）
    // 取消注释以把对应的 C++ 功能（operator / union 等）暴露到 Rust
    // 不需要就保持注释，对生成的 Rust crate 无影响
    // ============================================================
{% for w in suggested_wrappers %}{% for line in w.cpp_code.split("\n") %}
    // {{ line }}
{% endfor %}{% endfor %}{% endif %}
}
{% if classes %}{% for cls in classes %}
hicc::import_class! {
    #[cpp(class = "{{ cls.cpp_full_name }}"{% if cls.destroy %}, destroy = "{{ cls.destroy }}"{% endif %})]
    pub class {{ cls.rust_name }} {
        {% for m in cls.methods %}{% if m.rust_self %}
        #[cpp(method = "{{ m.cpp_method_sig }}")]
        pub fn {{ m.rust_name }}({{ m.rust_self }}{% if m.rust_param_decl %}, {{ m.rust_param_decl }}{% endif %}) -> {{ m.rust_return }};
        {% endif %}{% endfor %}
    }
}
{% endfor %}{% endif %}
hicc::import_lib! {
    #![link_name = "hicc_usage_{{ name }}_adapter"]
    {% for cls in classes %}
    pub class {{ cls.rust_name }};
    {% endfor %}{% for f in factory_funcs %}
    #[cpp(func = "{{ f.cpp_sig }}")]
    pub fn {{ f.rust_name }}({% if f.rust_param_decl %}{{ f.rust_param_decl }}{% endif %}) -> {{ f.rust_return }};
    {% endfor %}{% for ff in free_functions %}
    #[cpp(func = "{{ ff.cpp_sig }}")]
    pub fn {{ ff.rust_name }}({% if ff.rust_param_decl %}{{ ff.rust_param_decl }}{% endif %}) -> {{ ff.rust_return }};
    {% endfor %}{% for tf in template_ffis %}
    #[cpp(func = "{{ tf.cpp_sig }}")]
    pub fn {{ tf.rust_name }}({% if tf.rust_param_decl %}{{ tf.rust_param_decl }}{% endif %}) -> {{ tf.rust_return }};
    {% endfor %}
{% for w in suggested_wrappers if w.rust_placement == "import_lib" %}{% for line in w.rust_code.split("\n") %}
    // {{ line }}
{% endfor %}{% endfor %}
}
{% for w in suggested_wrappers if w.rust_placement == "top_level" %}

// ============================================================
// 自动生成的顶层建议（取消注释启用，例如 union 包装类）
// ============================================================
{% for line in w.rust_code.split("\n") %}// {{ line }}
{% endfor %}{% endfor %}
